# SpeakForest Environment Variables
# Copy this to .env and fill in your API keys

# Required: Anthropic API Key (for Claude AI conversations)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: OpenAI API Key (for Whisper speech-to-text)
# If not provided, browser Web Speech API will be used as fallback
OPENAI_API_KEY=your_openai_api_key_here

# Server settings (optional)
HOST=0.0.0.0
PORT=8000
